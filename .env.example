# MigrateMate Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# -------------------- AI/LLM --------------------
# Required: Get your key at https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# -------------------- Database (Optional) --------------------
# SQLite is used by default, uncomment for PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/migratemate

# PostgreSQL settings (if using docker-compose)
POSTGRES_USER=migratemate
POSTGRES_PASSWORD=migratemate_secret
POSTGRES_DB=migratemate_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -------------------- Vector DB - Qdrant (Optional) --------------------
QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# -------------------- Graph DB - Neo4j (Optional) --------------------
NEO4J_USER=neo4j
NEO4J_PASSWORD=migratemate_neo4j
NEO4J_HOST=localhost
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474

# -------------------- Cache - Redis (Optional) --------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=migratemate_redis

# -------------------- Application --------------------
APP_NAME=MigrateMate
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-in-production

# Comma-separated list of allowed CORS origins (the frontend).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -------------------- Feature toggles --------------------
# The core Flask->FastAPI migration only needs GEMINI_API_KEY. The options below
# are OFF by default so the app starts in ~1s without Docker. Turn them on only
# when the matching optional services are actually running.
#
# ENABLE_DATABASE         -> initialise the Postgres-backed project store at startup
# ENABLE_VECTOR_SERVICES  -> load embeddings + Qdrant + Neo4j (RAG); needs requirements-rag.txt
# DB_ECHO                 -> log every SQL statement (noisy; debugging only)
ENABLE_DATABASE=false
ENABLE_VECTOR_SERVICES=false
DB_ECHO=false

# -------------------- Embedding Model (only if ENABLE_VECTOR_SERVICES=true) ----
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
